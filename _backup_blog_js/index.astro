  <script src="/js/blog/blog-renderer.js?v=2" defer is:inline></script>
  <script src="/js/blog/seo-manager.js?v=2" defer is:inline></script>
  <script src="/js/blog/app.js?v=2" defer is:inline></script>
  <script src="/js/blog/image-download.js?v=2" defer is:inline></script>
  <script src="/js/blog/share-module.js?v=2" defer is:inline></script>
  <script src="/js/blog/blog-detail-sidebar.js?v=2" defer is:inline></script>
  <script src="/js/blog/bilingual-control-v2.js?v=2" defer is:inline></script>
  <script src="/js/blog/stats.js?v=2" defer is:inline></script>
  <script src="/js/blog/interactions.js?v=2" defer is:inline></script>
</BlogLayout>
