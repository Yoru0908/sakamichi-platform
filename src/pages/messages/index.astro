---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { MessageCircle } from 'lucide-astro';
import MsgArchive from '@/components/messages/MsgArchive';
import GeoPassGate from '@/components/shared/GeoPassGate';
---

<BaseLayout title="MSG消息归档 - Sakamichi Tools">
  <GeoPassGate client:load />
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Page header -->
    <div class="mb-8">
      <div class="flex items-center gap-2 mb-2">
        <MessageCircle size={18} class="text-[var(--color-brand-hinata)]" />
        <h1 class="text-2xl font-bold text-[var(--text-primary)]">MSG消息归档</h1>
      </div>
      <p class="text-sm text-[var(--text-secondary)]">成员消息中文翻译归档，支持文字、图片、视频、语音</p>
    </div>

    <!-- MSG Archive (React hydrated) -->
    <MsgArchive client:load />
  </div>
</BaseLayout>
