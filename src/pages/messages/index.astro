---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { MessageCircle, Info, Lock, Shield } from 'lucide-astro';
import MsgArchive from '@/components/messages/MsgArchive';
---

<BaseLayout title="MSG消息归档 - Sakamichi Tools">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Page header -->
    <div class="mb-8">
      <div class="flex items-center gap-2 mb-2">
        <MessageCircle size={18} class="text-[var(--color-brand-hinata)]" />
        <h1 class="text-2xl font-bold text-[var(--text-primary)]">MSG消息归档</h1>
      </div>
      <p class="text-sm text-[var(--text-secondary)]">成员消息中文翻译归档，支持文字、图片、视频、语音</p>
      
      <!-- Content access notice -->
      <div class="mt-4 rounded-lg border border-[var(--border-primary)] bg-[var(--bg-secondary)] p-3">
        <div class="flex items-start gap-2.5">
          <Info size={14} class="text-[var(--text-tertiary)] shrink-0 mt-0.5" />
          <div class="text-xs text-[var(--text-tertiary)] space-y-1">
            <p class="font-medium text-[var(--text-secondary)]">内容分级说明</p>
            <div class="flex flex-wrap gap-x-4 gap-y-1">
              <span>游客 → 消息翻译</span>
              <span class="flex items-center gap-1"><Lock size={10} /> 登录用户 → 原文、图片、视频</span>
              <span class="flex items-center gap-1"><Shield size={10} /> 认证用户 → 语音消息</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- MSG Archive (React hydrated) -->
    <MsgArchive client:load />
  </div>
</BaseLayout>
