---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="联系方式 - Sakamichi Tools">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-2xl font-bold text-[var(--text-primary)] mb-8">联系方式</h1>
    <div class="prose prose-sm max-w-none text-[var(--text-secondary)] space-y-4">
      <p>如有问题、建议或版权相关事宜，请通过以下方式联系：</p>
      <ul class="list-disc list-inside space-y-2">
        <li><strong>Discord</strong> — 加入我们的服务器获取支持</li>
        <li><strong>GitHub</strong> — 提交 Issue 或 Pull Request</li>
      </ul>
    </div>
  </div>
</BaseLayout>
