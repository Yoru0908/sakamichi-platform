---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="登录中 - Sakamichi Tools">
  <div class="min-h-[calc(100vh-7rem)] flex items-center justify-center py-10 px-4">
    <div class="text-center">
      <div class="w-8 h-8 border-2 border-t-transparent rounded-full animate-spin mx-auto mb-4" style="border-color: var(--color-brand-nogi) transparent var(--color-brand-nogi) var(--color-brand-nogi);"></div>
      <p class="text-sm text-[var(--text-secondary)]">正在完成登录...</p>
      <p class="text-xs text-[var(--text-tertiary)] mt-1">请稍候</p>
    </div>
  </div>

  <script>
    import { initAuth } from '@/stores/auth';

    async function handleCallback() {
      try {
        // The OAuth callback URL sets cookies server-side,
        // then redirects here. We just need to fetch user info.
        await initAuth();

        const { $auth } = await import('@/stores/auth');
        const auth = $auth.get();

        if (auth.isLoggedIn) {
          if (auth.isFirstLogin) {
            window.location.href = '/auth/onboarding';
          } else {
            window.location.href = '/';
          }
        } else {
          window.location.href = '/auth/login?error=oauth_failed';
        }
      } catch {
        window.location.href = '/auth/login?error=oauth_failed';
      }
    }

    handleCallback();
  </script>
</BaseLayout>
