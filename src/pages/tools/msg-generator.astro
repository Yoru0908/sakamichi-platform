---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MsgGenerator from '@/components/messages/MsgGenerator';
import { MessageSquare, ArrowLeft } from 'lucide-astro';
---

<BaseLayout title="MSG样式生成器 - Sakamichi Tools">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="mb-6">
      <a href="/tools" class="inline-flex items-center gap-1 text-xs text-[var(--text-tertiary)] hover:text-[var(--color-brand-nogi)] transition-colors mb-3">
        <ArrowLeft size={12} /> 返回工具箱
      </a>
      <div class="flex items-center gap-2">
        <div class="w-9 h-9 rounded-lg flex items-center justify-center" style="background: color-mix(in srgb, var(--color-brand-hinata) 12%, transparent); color: var(--color-brand-hinata);">
          <MessageSquare size={18} />
        </div>
        <div>
          <h1 class="text-xl font-bold text-[var(--text-primary)]">MSG样式生成器</h1>
          <p class="text-xs text-[var(--text-tertiary)]">坂道MSG聊天气泡截图生成工具</p>
        </div>
      </div>
    </div>

    <!-- Native MSG Generator -->
    <MsgGenerator client:load />
  </div>
</BaseLayout>
