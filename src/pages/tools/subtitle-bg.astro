---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Film, ArrowLeft, Upload, Palette } from 'lucide-astro';
---

<BaseLayout title="字幕底图制作 - Sakamichi Tools">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="mb-6">
      <a href="/tools" class="inline-flex items-center gap-1 text-xs text-[var(--text-tertiary)] hover:text-[var(--color-brand-nogi)] transition-colors mb-3">
        <ArrowLeft size={12} /> 返回工具箱
      </a>
      <div class="flex items-center gap-2">
        <div class="w-9 h-9 rounded-lg flex items-center justify-center" style="background: color-mix(in srgb, var(--color-brand-nogi) 12%, transparent); color: var(--color-brand-nogi);">
          <Film size={18} />
        </div>
        <div>
          <h1 class="text-xl font-bold text-[var(--text-primary)]">字幕底图制作</h1>
          <p class="text-xs text-[var(--text-tertiary)]">为视频字幕添加背景底图</p>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <!-- Left: Upload & Settings -->
      <div class="space-y-4">
        <!-- Upload -->
        <div class="rounded-xl border border-[var(--border-primary)] bg-[var(--bg-primary)] p-5">
          <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-3">上传底图</h3>
          <div id="drop-area" class="border-2 border-dashed border-[var(--border-secondary)] rounded-lg p-8 text-center cursor-pointer hover:border-[var(--color-brand-nogi)] transition-colors bg-[var(--bg-secondary)]">
            <p class="text-sm text-[var(--text-tertiary)] mb-2">拖拽图片到这里，或者</p>
            <button type="button" id="btn-select-img" class="px-4 py-2 text-sm font-medium rounded-lg text-white transition-colors" style="background: var(--color-brand-nogi);">
              选择图片
            </button>
            <input id="img-input" type="file" accept="image/*" class="hidden" />
          </div>
        </div>

        <!-- Settings -->
        <div class="rounded-xl border border-[var(--border-primary)] bg-[var(--bg-primary)] p-5">
          <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-3">底图设置</h3>
          <div class="space-y-3">
            <div>
              <label class="text-xs text-[var(--text-secondary)] mb-1 block">字幕位置</label>
              <select id="subtitle-position" class="w-full px-3 py-2 border border-[var(--border-primary)] rounded-lg text-sm bg-[var(--bg-secondary)] text-[var(--text-primary)]">
                <option value="bottom">底部</option>
                <option value="top">顶部</option>
                <option value="center">居中</option>
              </select>
            </div>
            <div>
              <label class="text-xs text-[var(--text-secondary)] mb-1 block">底图高度 (px): <span id="height-value" class="font-medium" style="color: var(--color-brand-nogi);">80</span></label>
              <input id="height-slider" type="range" min="40" max="200" step="5" value="80" class="w-full accent-[var(--color-brand-nogi)]" />
            </div>
            <div>
              <label class="text-xs text-[var(--text-secondary)] mb-1 block">底图颜色</label>
              <div class="flex items-center gap-2">
                <input id="bg-color" type="color" value="#000000" class="w-8 h-8 rounded border border-[var(--border-primary)] cursor-pointer" />
                <input id="bg-opacity" type="range" min="0" max="100" step="5" value="70" class="flex-1 accent-[var(--color-brand-nogi)]" />
                <span id="opacity-value" class="text-xs text-[var(--text-tertiary)] w-10 text-right">70%</span>
              </div>
            </div>
            <div>
              <label class="text-xs text-[var(--text-secondary)] mb-1 block">输出尺寸</label>
              <div class="grid grid-cols-2 gap-2">
                <div class="flex items-center gap-1">
                  <label class="text-[10px] text-[var(--text-tertiary)]">宽</label>
                  <input id="out-width" type="number" value="1920" class="flex-1 px-2 py-1.5 border border-[var(--border-primary)] rounded-lg text-xs bg-[var(--bg-secondary)] text-[var(--text-primary)]" />
                </div>
                <div class="flex items-center gap-1">
                  <label class="text-[10px] text-[var(--text-tertiary)]">高</label>
                  <input id="out-height" type="number" value="1080" class="flex-1 px-2 py-1.5 border border-[var(--border-primary)] rounded-lg text-xs bg-[var(--bg-secondary)] text-[var(--text-primary)]" />
                </div>
              </div>
            </div>
            <button id="btn-generate" class="w-full px-4 py-2.5 text-sm font-medium rounded-lg text-white transition-colors" style="background: var(--color-brand-nogi);">
              生成底图
            </button>
            <button id="btn-download" class="w-full px-4 py-2 text-sm font-medium rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white transition-colors" disabled>
              下载底图
            </button>
          </div>
        </div>
      </div>

      <!-- Right: Preview -->
      <div>
        <div class="rounded-xl border border-[var(--border-primary)] bg-[var(--bg-primary)] p-5 sticky top-20">
          <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-3">预览</h3>
          <div id="preview-container" class="aspect-video rounded-lg bg-[var(--bg-tertiary)] flex items-center justify-center overflow-hidden">
            <canvas id="preview-canvas" class="w-full h-full hidden"></canvas>
            <p id="preview-placeholder" class="text-xs text-[var(--text-tertiary)]">上传图片后预览</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const imgInput = document.getElementById('img-input');
      const btnSelect = document.getElementById('btn-select-img');
      const dropArea = document.getElementById('drop-area');
      const canvas = document.getElementById('preview-canvas');
      const placeholder = document.getElementById('preview-placeholder');
      const ctx = canvas.getContext('2d');
      let sourceImg = null;

      btnSelect.addEventListener('click', () => imgInput.click());
      imgInput.addEventListener('change', (e) => { if (e.target.files[0]) loadImage(e.target.files[0]); });
      dropArea.addEventListener('dragover', (e) => { e.preventDefault(); dropArea.style.borderColor = 'var(--color-brand-nogi)'; });
      dropArea.addEventListener('dragleave', () => { dropArea.style.borderColor = ''; });
      dropArea.addEventListener('drop', (e) => {
        e.preventDefault(); dropArea.style.borderColor = '';
        if (e.dataTransfer.files[0]) loadImage(e.dataTransfer.files[0]);
      });

      function loadImage(file) {
        const reader = new FileReader();
        reader.onload = (e) => {
          const img = new Image();
          img.onload = () => { sourceImg = img; canvas.classList.remove('hidden'); placeholder.classList.add('hidden'); renderPreview(); };
          img.src = e.target.result;
        };
        reader.readAsDataURL(file);
      }

      // Sliders
      const heightSlider = document.getElementById('height-slider');
      const heightValue = document.getElementById('height-value');
      const bgOpacity = document.getElementById('bg-opacity');
      const opacityValue = document.getElementById('opacity-value');
      heightSlider.addEventListener('input', () => { heightValue.textContent = heightSlider.value; renderPreview(); });
      bgOpacity.addEventListener('input', () => { opacityValue.textContent = bgOpacity.value + '%'; renderPreview(); });
      document.getElementById('bg-color').addEventListener('input', renderPreview);
      document.getElementById('subtitle-position').addEventListener('change', renderPreview);

      function renderPreview() {
        if (!sourceImg) return;
        const w = parseInt(document.getElementById('out-width').value) || 1920;
        const h = parseInt(document.getElementById('out-height').value) || 1080;
        canvas.width = w; canvas.height = h;
        ctx.drawImage(sourceImg, 0, 0, w, h);
        const barH = parseInt(heightSlider.value);
        const color = document.getElementById('bg-color').value;
        const alpha = parseInt(bgOpacity.value) / 100;
        const pos = document.getElementById('subtitle-position').value;
        const r = parseInt(color.slice(1,3),16), g = parseInt(color.slice(3,5),16), b = parseInt(color.slice(5,7),16);
        ctx.fillStyle = `rgba(${r},${g},${b},${alpha})`;
        let y = pos === 'top' ? 0 : pos === 'center' ? (h - barH) / 2 : h - barH;
        ctx.fillRect(0, y, w, barH);
        document.getElementById('btn-download').disabled = false;
      }

      document.getElementById('btn-generate').addEventListener('click', renderPreview);
      document.getElementById('btn-download').addEventListener('click', () => {
        if (!sourceImg) return;
        const link = document.createElement('a');
        link.download = 'subtitle_bg.png';
        link.href = canvas.toDataURL('image/png');
        link.click();
      });
    });
  </script>
</BaseLayout>
