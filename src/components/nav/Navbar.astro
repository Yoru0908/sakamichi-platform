---
import { NAV_ITEMS } from '@/utils/navigation';
import { t } from '@/i18n';
import ThemeToggle from '@/components/ui/ThemeToggle';
import LanguageSwitch from '@/components/ui/LanguageSwitch';
import ToolsDropdown from './ToolsDropdown';
import MobileDrawer from './MobileDrawer';
import AuthButton from './AuthButton';

interface Props {
  hideMobileDrawer?: boolean;
}

const { hideMobileDrawer = false } = Astro.props;
const currentPath = Astro.url.pathname;
---

<nav class="sticky top-0 z-40 bg-[var(--bg-primary)]/80 backdrop-blur-lg border-b border-[var(--border-primary)]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14">
      <!-- Logo -->
      <a
        href="/"
        data-astro-reload
        class="flex items-center gap-2 text-lg font-bold tracking-tight text-[var(--text-primary)] hover:text-[var(--color-brand-nogi)] transition-colors"
      >
        Sakamichi Tools
      </a>

      <!-- Desktop links -->
      <div class="hidden md:flex items-center gap-6">
        {NAV_ITEMS.map((item) =>
          item.children ? (
            <ToolsDropdown
              client:load
              item={item}
              currentPath={currentPath}
            />
          ) : (
            <a
              href={item.href}
              {...(item.href === '/blog' ? { 'data-astro-reload': true } : {})}
              class:list={[
                'px-1 py-2 text-sm font-medium transition-colors',
                currentPath === item.href || currentPath.startsWith(item.href + '/')
                  ? 'text-[var(--color-brand-nogi)]'
                  : 'text-[var(--text-secondary)] hover:text-[var(--text-primary)]',
              ]}
            >
              {t(item.labelKey, 'zh')}
            </a>
          )
        )}
      </div>

      <!-- Right actions -->
      <div class="flex items-center gap-1">
        <ThemeToggle client:load />
        <LanguageSwitch client:load />

        <!-- Auth button (desktop, dynamic) -->
        <AuthButton client:load />

        {/* Mobile hamburger (hidden when hideMobileDrawer is true) */}
        {!hideMobileDrawer && (
          <button
            id="mobile-menu-trigger"
            class="md:hidden p-2 rounded-lg text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)] transition-colors"
            aria-label="Open menu"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        )}
      </div>
    </div>
  </div>
</nav>

<!-- Mobile drawer (React island) -->
{!hideMobileDrawer && <MobileDrawer client:load currentPath={currentPath} />}

<script>
  import { toggleDrawer } from '@/stores/ui';

  document.getElementById('mobile-menu-trigger')?.addEventListener('click', toggleDrawer);
</script>
