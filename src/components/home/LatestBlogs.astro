---
import { Pen, ArrowRight } from 'lucide-astro';
import { GROUP_COLORS } from '@/utils/mock-data';

interface Props {
  blogs?: any[];
}

const { blogs = [] } = Astro.props;
---

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <div class="flex items-center justify-between mb-3">
    <div class="flex items-center gap-2 text-[var(--text-tertiary)]">
      <Pen size={14} />
      <h2 class="text-xs font-semibold uppercase tracking-wider">最新博客翻译</h2>
    </div>
    <a href="/blog" data-astro-reload class="flex items-center gap-1 text-xs font-medium text-[var(--color-brand-nogi)] hover:underline">
      查看全部 <ArrowRight size={12} />
    </a>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    {blogs.map((blog) => (
      <a
        href={`/blog#blog/${blog.id}`}
        data-astro-reload
        class="group flex flex-col rounded-xl border border-[var(--border-primary)] bg-[var(--bg-primary)] hover:-translate-y-0.5 hover:shadow-md transition-all duration-200 overflow-hidden"
      >
        {/* Blog thumbnail */}
        {blog.image && (
          <div class="w-full h-28 bg-[var(--bg-tertiary)] overflow-hidden">
            <img
              src={blog.image}
              alt={blog.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
        )}

        <div class="p-4 flex flex-col flex-1">
          {/* Avatar + meta */}
          <div class="flex items-center gap-3 mb-3">
            <div
              class="w-8 h-8 rounded-full shrink-0 flex items-center justify-center text-white text-xs font-bold"
              style={`background-color: ${GROUP_COLORS[blog.group]};`}
            >
              {blog.member_name.charAt(0)}
            </div>
            <div class="min-w-0">
              <p class="text-sm font-medium text-[var(--text-primary)] truncate">{blog.member_name}</p>
              <p class="text-[10px] text-[var(--text-tertiary)]">{blog.formatted_date}</p>
            </div>
          </div>

          {/* Title + preview */}
          <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-1 truncate">
            {blog.title}
          </h3>
          <p class="text-xs text-[var(--text-tertiary)] leading-relaxed line-clamp-2 flex-1">
            {blog.preview}
          </p>

          {/* Group indicator */}
          <div class="mt-3 flex items-center gap-1.5">
            <span
              class="w-1.5 h-1.5 rounded-full shrink-0"
              style={`background-color: ${GROUP_COLORS[blog.group]};`}
            />
            <span class="text-[10px] text-[var(--text-tertiary)]">
              {blog.group_name}
            </span>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>
