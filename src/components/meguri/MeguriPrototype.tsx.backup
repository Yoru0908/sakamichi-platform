import { useMemo, useState } from 'react';
import {
  CalendarDays,
  Clock3,
  ExternalLink,
  Layers3,
  PanelLeftClose,
  PanelLeft,
  Search,
  Plus,
  Sparkles,
  Ticket,
  X,
  Users,
} from 'lucide-react';
import type { FortuneEvent, GroupId, ReceptionWindow } from '@/utils/fortune-music';

type Entry = {
  id: string;
  member: string;
  date: string;
  slot: number;
  tickets: number;
  status: 'planned' | 'won' | 'paid';
};

type AddForm = {
  date: string;
  slots: number[];
  members: string[];
  tickets: number;
  status: Entry['status'];
  search: string;
};

interface Props {
  events: string; // JSON string of FortuneEvent[]
}

const GROUP_META: Record<GroupId, { label: string; color: string; soft: string }> = {
  nogizaka: { label: '乃木坂46', color: 'var(--color-brand-nogi)', soft: 'rgba(116, 37, 129, 0.12)' },
  hinatazaka: { label: '日向坂46', color: 'var(--color-brand-hinata)', soft: 'rgba(56, 189, 248, 0.14)' },
  sakurazaka: { label: '櫻坂46', color: 'var(--color-brand-saku)', soft: 'rgba(244, 114, 182, 0.14)' },
};

const SLOT_NUMBERS = [1, 2, 3, 4, 5, 6];

const EVENT_DATES: Record<string, string[]> = {
  hinatazaka_202605: ['2026/05/24', '2026/05/31', '2026/06/07', '2026/06/14', '2026/06/21'],
  nogizaka_202604: ['2026/04/29', '2026/05/05', '2026/05/10', '2026/05/17', '2026/05/24'],
  sakurazaka_202603: ['2026/04/20', '2026/04/27', '2026/05/04', '2026/05/11', '2026/05/18'],
};

const FAVORITE_MEMBERS: Record<GroupId, string[]> = {
  nogizaka: ['井上和', '賀喜遥香', '川﨑桜', '中西アルノ'],
  hinatazaka: ['小坂菜緒', '正源司陽子', '藤嶌果歩', '宮地すみれ'],
  sakurazaka: ['山﨑天', '守屋麗奈', '谷口愛季', '村井優'],
};

const ALL_MEMBERS: Record<GroupId, string[]> = {
  nogizaka: ['井上和', '賀喜遥香', '川﨑桜', '中西アルノ', '遠藤さくら', '池田瑛紗', '菅原咲月', '五百城茉央'],
  hinatazaka: ['小坂菜緒', '正源司陽子', '藤嶌果歩', '宮地すみれ', '金村美玖', '松田好花', '河田陽菜', '山下葉留花'],
  sakurazaka: ['山﨑天', '守屋麗奈', '谷口愛季', '村井優', '田村保乃', '森田ひかる', '藤吉夏鈴', '的野美青'],
};

// Sample personal entries (placeholder for future DB-backed data)
const SAMPLE_ENTRIES: Record<string, Entry[]> = {
  hinatazaka_202605: [
    { id: 'h1', member: '小坂菜緒', date: '2026/05/24', slot: 2, tickets: 3, status: 'paid' },
    { id: 'h2', member: '小坂菜緒', date: '2026/05/24', slot: 2, tickets: 2, status: 'won' },
    { id: 'h3', member: '正源司陽子', date: '2026/05/31', slot: 4, tickets: 4, status: 'paid' },
    { id: 'h4', member: '藤嶌果歩', date: '2026/05/31', slot: 4, tickets: 2, status: 'planned' },
    { id: 'h5', member: '宮地すみれ', date: '2026/05/31', slot: 4, tickets: 1, status: 'planned' },
  ],
  nogizaka_202604: [
    { id: 'n1', member: '井上和', date: '2026/04/29', slot: 1, tickets: 3, status: 'paid' },
    { id: 'n2', member: '中西アルノ', date: '2026/04/29', slot: 2, tickets: 2, status: 'won' },
    { id: 'n3', member: '贺喜遥香', date: '2026/05/05', slot: 4, tickets: 5, status: 'planned' },
    { id: 'n4', member: '川崎桜', date: '2026/05/05', slot: 4, tickets: 2, status: 'planned' },
  ],
  sakurazaka_202603: [
    { id: 's1', member: '山﨑天', date: '2026/04/20', slot: 2, tickets: 2, status: 'paid' },
    { id: 's2', member: '守屋麗奈', date: '2026/04/20', slot: 3, tickets: 1, status: 'paid' },
    { id: 's3', member: '谷口愛季', date: '2026/04/27', slot: 4, tickets: 2, status: 'paid' },
  ],
};

function stateTone(state: 'active' | 'upcoming' | 'ended' | 'waiting') {
  if (state === 'active') return 'rgba(16, 185, 129, 0.14)';
  if (state === 'upcoming') return 'rgba(59, 130, 246, 0.14)';
  if (state === 'waiting') return 'rgba(100, 116, 139, 0.14)';
  return 'rgba(148, 163, 184, 0.14)';
}

function stateLabel(state: 'active' | 'upcoming' | 'ended' | 'waiting', eventDateHasPassed: boolean = false) {
  if (state === 'active') return '受付中';
  if (state === 'upcoming') return '即将开始';
  if (state === 'waiting') return '等待下轮续报';
  return eventDateHasPassed ? '全部结束' : '当前轮次已结';
}

function inferEventState(windows: ReceptionWindow[], lastEventDate?: string): 'active' | 'upcoming' | 'ended' | 'waiting' {
  const now = new Date();
  
  // 1. 检查是否有正在进行的
  const hasActive = windows.some(w => {
    const start = new Date(w.start.replace(/年|月/g, '/').replace(/日/g, '').replace(/[（(][^)）]+[)）]/g, '').replace(/[：:]/g, ':').trim());
    const end = new Date(w.end.replace(/年|月/g, '/').replace(/日/g, '').replace(/[（(][^)）]+[)）]/g, '').replace(/[：:]/g, ':').trim());
    return !isNaN(start.getTime()) && !isNaN(end.getTime()) && start <= now && end > now;
  });
  if (hasActive) return 'active';

  // 2. 检查是否有未来的
  const hasUpcoming = windows.some(w => {
    const start = new Date(w.start.replace(/年|月/g, '/').replace(/日/g, '').replace(/[（(][^)）]+[)）]/g, '').replace(/[：:]/g, ':').trim());
    return !isNaN(start.getTime()) && start > now;
  });
  if (hasUpcoming) return 'upcoming';

  // 3. 如果所有已知轮次都结束了，但活动日期还没过完，说明在等下一轮
  if (lastEventDate) {
    const lastDate = new Date(lastEventDate);
    if (lastDate > now) return 'waiting';
  }

  return 'ended';
}

function statusLabel(status: Entry['status']) {
  if (status === 'paid') return '已支付';
  if (status === 'won') return '已中签';
  return '待确认';
}

function statusTone(status: Entry['status']) {
  if (status === 'paid') return { bg: 'rgba(16, 185, 129, 0.14)', text: '#059669' };
  if (status === 'won') return { bg: 'rgba(59, 130, 246, 0.14)', text: '#2563eb' };
  return { bg: 'rgba(245, 158, 11, 0.14)', text: '#d97706' };
}

export default function MeguriPrototype({ events: eventsJson }: Props) {
  const events: FortuneEvent[] = useMemo(() => {
    try { return JSON.parse(eventsJson); } catch { return []; }
  }, [eventsJson]);

  const [selectedSlug, setSelectedSlug] = useState<string>(() => events[0]?.slug || '');
  const [isSidebarOpen, setIsSidebarOpen] = useState(true);
  const [entryState, setEntryState] = useState<Record<string, Entry[]>>(SAMPLE_ENTRIES);
  const [isAddOpen, setIsAddOpen] = useState(false);
  const selectedEvent = events.find((e) => e.slug === selectedSlug) || events[0];

  const selectedGroup = selectedEvent?.group || 'hinatazaka';
  const availableDates = selectedEvent ? (EVENT_DATES[selectedEvent.slug] || [...new Set((entryState[selectedEvent.slug] || []).map((e) => e.date))]) : [];
  const [addForm, setAddForm] = useState<AddForm>({
    date: availableDates[0] || '2026/05/24',
    slots: [],
    members: [],
    tickets: 1,
    status: 'paid',
    search: '',
  });

  const entries = selectedEvent ? (entryState[selectedEvent.slug] || []) : [];
  const favoriteMembers = FAVORITE_MEMBERS[selectedGroup];
  const allMembers = ALL_MEMBERS[selectedGroup];
  const filteredMembers = allMembers.filter((member) => member.includes(addForm.search.trim()));

  const summary = useMemo(() => {
    const totalTickets = entries.reduce((sum, e) => sum + e.tickets, 0);
    const totalSlots = entries.length;
    const uniqueMembers = new Set(entries.map((e) => e.member)).size;
    const uniqueDates = new Set(entries.map((e) => e.date)).size;
    return { totalTickets, totalSlots, uniqueMembers, uniqueDates };
  }, [entries]);

  const groupedEntries = useMemo(() => {
    const groups: Record<string, Record<number, Entry[]>> = {};
    entries.forEach((e) => {
      if (!groups[e.date]) groups[e.date] = {};
      if (!groups[e.date][e.slot]) groups[e.date][e.slot] = [];
      groups[e.date][e.slot].push(e);
    });
    return groups;
  }, [entries]);

  const openAddDrawer = () => {
    setAddForm((current) => ({
      ...current,
      date: availableDates.includes(current.date) ? current.date : availableDates[0] || current.date,
      slots: [],
    }));
    setIsAddOpen(true);
  };

  const toggleAddSlot = (slot: number) => {
    setAddForm((current) => ({
      ...current,
      slots: current.slots.includes(slot)
        ? current.slots.filter((s) => s !== slot)
        : [...current.slots, slot].sort(),
    }));
  };

  const toggleAddMember = (member: string) => {
    setAddForm((current) => ({
      ...current,
      members: current.members.includes(member)
        ? current.members.filter((name) => name !== member)
        : [...current.members, member],
    }));
  };

  const saveAddForm = () => {
    if (!selectedEvent || addForm.members.length === 0 || addForm.slots.length === 0) return;
    const createdAt = Date.now();
    const newEntries: Entry[] = [];
    
    addForm.slots.forEach((slot) => {
      addForm.members.forEach((member, mIdx) => {
        newEntries.push({
          id: `${selectedEvent.slug}-${createdAt}-${slot}-${mIdx}`,
          member,
          date: addForm.date,
          slot,
          tickets: addForm.tickets,
          status: addForm.status,
        });
      });
    });

    setEntryState((current) => ({
      ...current,
      [selectedEvent.slug]: [...(current[selectedEvent.slug] || []), ...newEntries],
    }));
    setAddForm((current) => ({ ...current, members: [], slots: [], tickets: 1, search: '' }));
    setIsAddOpen(false);
  };

  if (events.length === 0) {
    return (
      <div className="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
        <div className="text-4xl mb-4">⚠️</div>
        <h1 className="text-xl font-bold text-[var(--text-primary)]">无法从 Fortune Music 获取活动数据</h1>
        <p className="mt-2 text-sm text-[var(--text-tertiary)]">
          构建时 fetch fortunemusic.jp/event_list/ 失败。请检查网络或稍后重试构建。
        </p>
      </div>
    );
  }

  const lastEventDate = availableDates[availableDates.length - 1];
  const eventState = selectedEvent ? inferEventState(selectedEvent.windows, lastEventDate) : 'ended';
  const isEventOver = lastEventDate ? new Date(lastEventDate) < new Date() : true;

  return (
    <div className="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">
      <section className="relative overflow-hidden rounded-3xl border border-[var(--border-primary)] bg-[var(--bg-primary)] p-6 sm:p-8">
        <div
          className="absolute inset-0 opacity-80"
          style={{
            background:
              'radial-gradient(circle at top right, rgba(125, 211, 252, 0.18), transparent 28%), radial-gradient(circle at left center, rgba(244, 114, 182, 0.14), transparent 30%)',
          }}
        />
        <div className="relative flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
          <div className="max-w-3xl">
            <div className="inline-flex items-center gap-2 rounded-full border border-[var(--border-primary)] bg-[var(--bg-secondary)] px-3 py-1 text-[11px] font-medium text-[var(--text-secondary)]">
              <Sparkles size={12} />
              Hidden prototype · 咪咕力活动管理
            </div>
            <h1 className="mt-4 text-3xl font-bold tracking-tight text-[var(--text-primary)] sm:text-4xl">
              咪咕力管理页
            </h1>
            <p className="mt-3 max-w-2xl text-sm leading-6 text-[var(--text-secondary)] sm:text-[15px]">
              数据来自 fortunemusic.jp/event_list/ 实时抓取。你可以折叠左侧活动列表，右侧的清单支持同日同部多成员的紧凑网格展示。
            </p>
          </div>
          <div className="grid grid-cols-2 gap-3 sm:w-[360px]">
            {[
              { label: '坂道活动数', value: events.length, icon: Layers3, color: '#7c3aed' },
              { label: '当前活动', value: stateLabel(eventState), icon: Clock3, color: '#10b981' },
            ].map((item) => {
              const Icon = item.icon;
              return (
                <div key={item.label} className="rounded-2xl border border-[var(--border-primary)] bg-[var(--bg-secondary)] p-4">
                  <div className="flex items-center gap-2 text-[10px] uppercase tracking-[0.18em] text-[var(--text-tertiary)]">
                    <Icon size={12} style={{ color: item.color }} />
                    {item.label}
                  </div>
                  <div className="mt-2 text-2xl font-bold text-[var(--text-primary)]">{item.value}</div>
                </div>
              );
            })}
          </div>
        </div>
      </section>

      <section className="flex flex-col lg:flex-row gap-6 lg:gap-8 items-start">
        {/* Left Sidebar */}
        <div
          className={`w-full transition-all duration-300 ${
            isSidebarOpen ? 'lg:w-[340px] xl:w-[380px] shrink-0' : 'hidden'
          }`}
        >
          <div className="sticky top-8 space-y-4">
            <div className="flex items-center justify-between">
              <div>
                <h2 className="text-lg font-semibold text-[var(--text-primary)]">活动总览</h2>
              </div>
              <button
                onClick={() => setIsSidebarOpen(false)}
                className="hidden lg:flex items-center gap-1.5 rounded-full border border-[var(--border-primary)] bg-[var(--bg-secondary)] px-3 py-1 text-xs text-[var(--text-tertiary)] hover:bg-[var(--bg-primary)] hover:text-[var(--text-primary)] transition-colors"
              >
                <PanelLeftClose size={12} /> 收起
              </button>
            </div>

            <div className="space-y-3">
              {events.map((event) => {
                const groupMeta = GROUP_META[event.group];
                if (!groupMeta) return null;
                const isActive = event.slug === selectedEvent?.slug;
                const evState = inferEventState(event.windows);
                const lastWindow = event.windows[event.windows.length - 1];
                const eventEntries = SAMPLE_ENTRIES[event.slug] || [];
                const eventTickets = eventEntries.reduce((sum, e) => sum + e.tickets, 0);

                return (
                  <button
                    key={event.slug}
                    type="button"
                    onClick={() => setSelectedSlug(event.slug)}
                    className={`w-full rounded-3xl border p-5 text-left transition-all ${
                      isActive
                        ? 'border-transparent shadow-lg'
                        : 'border-[var(--border-primary)] bg-[var(--bg-primary)] hover:border-[var(--border-secondary)] hover:-translate-y-0.5'
                    }`}
                    style={
                      isActive
                        ? {
                            background: `linear-gradient(135deg, ${groupMeta.soft}, rgba(255,255,255,0.92))`,
                            boxShadow: '0 20px 40px rgba(15, 23, 42, 0.08)',
                          }
                        : undefined
                    }
                  >
                    <div className="flex items-start gap-3">
                      <div
                        className="mt-0.5 flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl text-sm font-bold text-white"
                        style={{ backgroundColor: groupMeta.color }}
                      >
                        {groupMeta.label.slice(0, 1)}
                      </div>
                      <div className="min-w-0 flex-1">
                        <div className="flex flex-wrap items-center gap-2">
                          <span className="text-xs font-medium" style={{ color: groupMeta.color }}>
                            {groupMeta.label}
                          </span>
                          <span
                            className="rounded-full px-2.5 py-1 text-[10px] font-medium"
                            style={{ backgroundColor: stateTone(evState), color: 'var(--text-secondary)' }}
                          >
                            {stateLabel(evState)}
                          </span>
                        </div>
                        <h3 className="mt-2 line-clamp-2 text-sm font-semibold leading-5 text-[var(--text-primary)]">
                          {event.title}
                        </h3>
                      </div>
                    </div>
                  </button>
                );
              })}
            </div>
          </div>
        </div>

        {/* Right Main Area */}
        {selectedEvent && (
          <div className="min-w-0 flex-1 w-full space-y-6">
            <div className="rounded-3xl border border-[var(--border-primary)] bg-[var(--bg-primary)] p-6">
              <div className="flex flex-col gap-4 border-b border-[var(--border-secondary)] pb-8 md:flex-row md:items-start md:justify-between">
              <div className="flex items-start gap-4 flex-1">
                <button
                  onClick={() => setIsSidebarOpen(!isSidebarOpen)}
                  className="mt-1 flex items-center justify-center h-10 w-10 shrink-0 rounded-2xl border border-[var(--border-primary)] bg-[var(--bg-secondary)] text-[var(--text-secondary)] hover:bg-[var(--bg-primary)] hover:text-[var(--text-primary)] transition-colors"
                  title={isSidebarOpen ? '折叠活动列表' : '展开活动列表'}
                >
                  {isSidebarOpen ? <PanelLeftClose size={20} /> : <PanelLeft size={20} />}
                </button>
                <div className="min-w-0 flex-1">
                  <div className="flex items-center gap-3">
                    <h2 className="text-2xl font-black text-[var(--text-primary)] sm:text-3xl truncate">{selectedEvent.title}</h2>
                    <span className={`shrink-0 rounded-full px-3 py-1 text-xs font-bold ${selectedEvent.group === 'hinatazaka' ? 'bg-sky-100 text-sky-700' : selectedEvent.group === 'nogizaka' ? 'bg-purple-100 text-purple-700' : 'bg-rose-100 text-rose-700'}`}>
                      {selectedEvent.group === 'hinatazaka' ? '日向坂46' : selectedEvent.group === 'nogizaka' ? '乃木坂46' : '櫻坂46'}
                    </span>
                  </div>
                  <div className="mt-3 flex flex-wrap items-center gap-x-4 gap-y-2">
                    <a
                      href={`https://fortunemusic.jp/event_list/`}
                      target="_blank"
                      rel="noopener noreferrer"
                      className="flex items-center gap-1 text-xs font-medium text-[var(--text-tertiary)] hover:text-[var(--text-secondary)]"
                    >
                      Fortune Music 原页 <ExternalLink size={14} />
                    </a>
                    <div className="hidden sm:block h-3 w-[1px] bg-[var(--border-secondary)]" />
                    <button className="flex items-center gap-1.5 text-xs font-medium text-emerald-600 hover:text-emerald-700">
                      <CalendarDays size={14} /> 全日程同步到日历
                    </button>
                  </div>
                </div>
              </div>
              
              <button
                type="button"
                onClick={openAddDrawer}
                className="shrink-0 flex items-center gap-2 rounded-2xl bg-[var(--text-primary)] px-5 py-2.5 text-sm font-bold text-white transition-all hover:opacity-90 active:scale-95"
              >
                <Plus size={18} /> 添加录入
              </button>
            </div>

              <div className="mt-6 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
                {[
                  { label: '我有多少部', value: summary.totalSlots, icon: Layers3, color: '#7c3aed' },
                  { label: '总张数', value: summary.totalTickets, icon: Ticket, color: '#f59e0b' },
                  { label: '都有谁', value: summary.uniqueMembers, icon: Users, color: '#2563eb' },
                  { label: '日历占几天', value: summary.uniqueDates, icon: CalendarDays, color: '#10b981' },
                ].map((item) => {
                  const Icon = item.icon;
                  return (
                    <div key={item.label} className="rounded-2xl border border-[var(--border-primary)] bg-[var(--bg-secondary)] p-4">
                      <div className="flex items-center gap-2 text-[11px] text-[var(--text-tertiary)]">
                        <Icon size={13} style={{ color: item.color }} />
                        {item.label}
                      </div>
                      <div className="mt-2 text-2xl font-bold text-[var(--text-primary)]">{item.value}</div>
                    </div>
                  );
                })}
              </div>
            </div>

            <div className="grid gap-6 xl:grid-cols-[1.4fr_0.6fr]">
              <div className="space-y-6">
                <div className="overflow-x-auto -mx-4 sm:mx-0">
                  <div className="min-w-[800px] p-1">
                    <table className="w-full border-separate border-spacing-2">
                      <thead>
                        <tr>
                          <th className="w-32 py-4 text-left text-sm font-bold text-[var(--text-tertiary)] pl-2">日期 / 部数</th>
                          {SLOT_NUMBERS.map((slot) => (
                            <th key={slot} className="py-4 text-center text-sm font-bold text-[var(--text-secondary)] bg-[var(--bg-secondary)] rounded-2xl border border-[var(--border-primary)]">
                              第 {slot} 部
                            </th>
                          ))}
                        </tr>
                      </thead>
                      <tbody>
                        {(availableDates.length > 0 ? availableDates : Object.keys(groupedEntries).sort()).map((date) => {
                          const slots = groupedEntries[date] || {};
                          return (
                            <tr key={date}>
                              <td className="py-4 pr-4 align-top">
                                <div className="text-sm font-bold text-[var(--text-primary)]">{date}</div>
                                <div className="mt-1 text-[10px] text-[var(--text-tertiary)] uppercase tracking-wider">
                                  {new Date(date).toLocaleDateString('zh-CN', { weekday: 'short' })}
                                </div>
                              </td>
                              {SLOT_NUMBERS.map((slotNumber) => {
                                const slotEntries = slots[slotNumber] || [];
                                return (
                                  <td
                                    key={`${date}-${slotNumber}`}
                                    className={`relative h-32 w-1/6 rounded-3xl border transition-all align-top p-3 group ${
                                      slotEntries.length > 0
                                        ? 'border-[var(--border-primary)] bg-[var(--bg-primary)] shadow-sm'
                                        : 'border-dashed border-[var(--border-secondary)] bg-[var(--bg-secondary)] hover:border-[var(--border-primary)]'
                                    }`}
                                  >
                                    {slotEntries.length > 0 ? (
                                      <div className="flex flex-col gap-2">
                                        {slotEntries.map((entry) => {
                                          const tone = statusTone(entry.status);
                                          return (
                                            <div
                                              key={entry.id}
                                              className="group/item relative flex flex-col rounded-xl border border-[var(--border-secondary)] bg-[var(--bg-secondary)] p-2 transition-all hover:border-[var(--border-primary)]"
                                            >
                                              <div className="flex items-center justify-between gap-1">
                                                <span className="truncate text-xs font-bold text-[var(--text-primary)]">
                                                  {entry.member}
                                                </span>
                                              </div>
                                              <div className="mt-1 flex items-center justify-between text-[10px] text-[var(--text-tertiary)]">
                                                <span>{entry.tickets}张</span>
                                              </div>
                                            </div>
                                          );
                                        })}
                                        <button
                                          onClick={() => {
                                            setAddForm((current) => ({ ...current, date, slots: [slotNumber] }));
                                            setIsAddOpen(true);
                                          }}
                                          className="mt-1 w-full rounded-lg border border-dashed border-[var(--border-secondary)] py-1 text-[10px] text-[var(--text-tertiary)] hover:bg-[var(--bg-secondary)] hover:text-[var(--text-secondary)]"
                                        >
                                          + 添加
                                        </button>
                                      </div>
                                    ) : (
                                      <button
                                        type="button"
                                        onClick={() => {
                                          setAddForm((current) => ({ ...current, date, slots: [slotNumber] }));
                                          setIsAddOpen(true);
                                        }}
                                        className="absolute inset-0 flex flex-col items-center justify-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity"
                                      >
                                        <div className="rounded-full bg-[var(--bg-primary)] p-1.5 shadow-sm border border-[var(--border-primary)]">
                                          <Plus size={14} className="text-[var(--text-secondary)]" />
                                        </div>
                                        <span className="text-[10px] text-[var(--text-tertiary)]">添加录入</span>
                                      </button>
                                    )}
                                  </td>
                                );
                              })}
                            </tr>
                          );
                        })}
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>

              <div className="space-y-6">
                <div className="sticky top-8 space-y-6">
                  <div className="rounded-3xl border border-[var(--border-primary)] bg-[var(--bg-primary)] p-6">
                    <h3 className="text-lg font-semibold text-[var(--text-primary)]">受付时间轴</h3>
                    <p className="mt-1 text-xs text-[var(--text-tertiary)]">
                      {selectedEvent.windows.length} 轮应募记录
                    </p>
                    {selectedEvent.windows.length === 0 ? (
                      <div className="mt-5 text-center py-4 text-sm text-[var(--text-tertiary)]">
                        受付日程未解析到
                      </div>
                    ) : (
                      <div className="mt-5 space-y-3">
                        {(() => {
                          const activeOrUpcomingIdx = selectedEvent.windows.findIndex(w => {
                            const end = new Date(w.end.replace(/年|月/g, '/').replace(/日/g, '').replace(/[（(][^)）]+[)）]/g, '').replace(/[：:]/g, ':').trim());
                            return !isNaN(end.getTime()) && end > new Date();
                          });
                          
                          // 如果轮次很多，折叠已结束的
                          const showIdx = activeOrUpcomingIdx === -1 ? selectedEvent.windows.length - 1 : activeOrUpcomingIdx;
                          const hasHistory = showIdx > 0;
                          
                          return (
                            <>
                              {hasHistory && (
                                <div className="text-center">
                                  <button className="text-[10px] text-[var(--text-tertiary)] hover:text-[var(--text-secondary)] py-1">
                                    —— 已隐藏前 {showIdx} 轮结束记录 ——
                                  </button>
                                </div>
                              )}
                              {selectedEvent.windows.slice(showIdx).map((window) => {
                                const wState = inferEventState([window]);
                                return (
                                  <div key={window.label + window.start} className={`rounded-2xl border p-4 transition-all ${wState === 'active' ? 'border-emerald-500/50 bg-emerald-500/5 shadow-sm' : 'border-[var(--border-primary)] bg-[var(--bg-secondary)]'}`}>
                                    <div className="flex items-center justify-between gap-2">
                                      <div className="text-sm font-semibold text-[var(--text-primary)]">{window.label}</div>
                                      <span
                                        className="rounded-full px-2.5 py-1 text-[10px]"
                                        style={{ 
                                          backgroundColor: wState === 'active' ? 'rgba(16, 185, 129, 0.2)' : stateTone(wState),
                                          color: wState === 'active' ? '#059669' : 'var(--text-secondary)'
                                        }}
                                      >
                                        {stateLabel(wState)}
                                      </span>
                                    </div>
                                    <div className="mt-2 text-xs leading-5 text-[var(--text-tertiary)]">
                                      开始：{window.start}
                                      <br />
                                      截止：{window.end}
                                    </div>
                                  </div>
                                );
                              })}
                              {eventState === 'waiting' && (
                                <div className="rounded-2xl border border-dashed border-[var(--border-primary)] bg-[var(--bg-secondary)] p-4 opacity-60">
                                  <div className="flex items-center justify-between gap-2">
                                    <div className="text-sm font-semibold text-[var(--text-tertiary)]">后续应募轮次</div>
                                    <span className="rounded-full bg-slate-100 px-2.5 py-1 text-[10px] text-slate-500">
                                      待续报
                                    </span>
                                  </div>
                                  <div className="mt-2 text-[10px] italic text-[var(--text-tertiary)]">
                                    通常单曲活动会有 6-12 轮应募，请留意官网后续通知。
                                  </div>
                                </div>
                              )}
                            </>
                          );
                        })()}
                      </div>
                    )}
                  </div>

                  <div className="rounded-3xl border border-[var(--border-primary)] bg-[var(--bg-primary)] p-6">
                    <h3 className="text-lg font-semibold text-[var(--text-primary)]">日历联动</h3>
                    <p className="mt-1 text-xs text-[var(--text-tertiary)]">正式版支持 ICS 导出 + 账号专属订阅 feed</p>
                    <div className="mt-5 rounded-2xl border border-dashed border-[var(--border-secondary)] bg-[var(--bg-secondary)] p-4">
                      <div className="flex items-center gap-2 text-sm font-medium text-[var(--text-primary)]">
                        <CalendarDays size={15} className="text-emerald-500" />
                        Apple / Google Calendar
                      </div>
                      <p className="mt-2 text-xs leading-5 text-[var(--text-tertiary)]">
                        本活动将生成 {summary.totalSlots} 个日历事件，支持提醒时间、webcal 订阅地址和 Google 一键添加。
                      </p>
                      <div className="mt-4 grid gap-2">
                        <button type="button" className="rounded-2xl bg-[var(--text-primary)] px-4 py-2.5 text-sm font-medium text-white">
                          预览导出 .ics
                        </button>
                        <button type="button" className="rounded-2xl border border-[var(--border-primary)] bg-[var(--bg-primary)] px-4 py-2.5 text-sm font-medium text-[var(--text-secondary)]">
                          未来：订阅专属日历
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        )}
      </section>

      {isAddOpen && selectedEvent && (
        <div className="fixed inset-0 z-50 flex justify-end bg-slate-950/30 backdrop-blur-sm">
          <button
            type="button"
            aria-label="关闭添加部数"
            className="absolute inset-0 cursor-default"
            onClick={() => setIsAddOpen(false)}
          />
          <aside className="relative h-full w-full max-w-[520px] overflow-y-auto border-l border-[var(--border-primary)] bg-[var(--bg-primary)] p-6 shadow-2xl">
            <div className="flex items-start justify-between gap-4">
              <div>
                <p className="text-xs font-medium text-[var(--text-tertiary)]">当前活动</p>
                <h3 className="mt-1 text-xl font-bold text-[var(--text-primary)]">添加部数</h3>
                <p className="mt-1 line-clamp-2 text-sm text-[var(--text-secondary)]">{selectedEvent.title}</p>
              </div>
              <button
                type="button"
                onClick={() => setIsAddOpen(false)}
                className="flex h-10 w-10 items-center justify-center rounded-2xl border border-[var(--border-primary)] bg-[var(--bg-secondary)] text-[var(--text-secondary)]"
              >
                <X size={18} />
              </button>
            </div>

            <div className="mt-8 space-y-7">
              <div>
                <label className="text-sm font-semibold text-[var(--text-primary)]">参加日期</label>
                <div className="mt-3 grid grid-cols-2 gap-2">
                  {availableDates.map((date) => (
                    <button
                      key={date}
                      type="button"
                      onClick={() => setAddForm((current) => ({ ...current, date }))}
                      className={`rounded-2xl border px-3 py-2 text-sm font-medium transition-colors ${
                        addForm.date === date
                          ? 'border-[var(--text-primary)] bg-[var(--text-primary)] text-white'
                          : 'border-[var(--border-primary)] bg-[var(--bg-secondary)] text-[var(--text-secondary)]'
                      }`}
                    >
                      {date}
                    </button>
                  ))}
                </div>
              </div>

              <div>
                <label className="text-sm font-semibold text-[var(--text-primary)]">第几部</label>
                <p className="text-[10px] text-[var(--text-tertiary)] mt-1">支持多选，将为选中的部数分别创建记录</p>
                <div className="mt-3 grid grid-cols-6 gap-2">
                  {SLOT_NUMBERS.map((slot) => (
                    <button
                      key={slot}
                      type="button"
                      onClick={() => toggleAddSlot(slot)}
                      className={`rounded-2xl border py-3 text-sm font-bold transition-colors ${
                        addForm.slots.includes(slot)
                          ? 'border-[var(--text-primary)] bg-[var(--text-primary)] text-white'
                          : 'border-[var(--border-primary)] bg-[var(--bg-secondary)] text-[var(--text-secondary)]'
                      }`}
                    >
                      {slot}
                    </button>
                  ))}
                </div>
              </div>

              <div>
                <div className="flex items-end justify-between gap-3">
                  <label className="text-sm font-semibold text-[var(--text-primary)]">お気に入りメンバー</label>
                  <span className="text-xs text-[var(--text-tertiary)]">账号收藏优先显示</span>
                </div>
                <div className="mt-3 flex flex-wrap gap-2">
                  {favoriteMembers.map((member) => {
                    const active = addForm.members.includes(member);
                    return (
                      <button
                        key={member}
                        type="button"
                        onClick={() => toggleAddMember(member)}
                        className={`rounded-full border px-3 py-2 text-sm font-medium transition-colors ${
                          active
                            ? 'border-transparent text-white'
                            : 'border-[var(--border-primary)] bg-[var(--bg-secondary)] text-[var(--text-secondary)]'
                        }`}
                        style={active ? { backgroundColor: GROUP_META[selectedGroup].color } : undefined}
                      >
                        {member}
                      </button>
                    );
                  })}
                </div>
              </div>

              <div>
                <label className="text-sm font-semibold text-[var(--text-primary)]">全成员搜索</label>
                <div className="mt-3 flex items-center gap-2 rounded-2xl border border-[var(--border-primary)] bg-[var(--bg-secondary)] px-4 py-3">
                  <Search size={16} className="text-[var(--text-tertiary)]" />
                  <input
                    value={addForm.search}
                    onChange={(event) => setAddForm((current) => ({ ...current, search: event.target.value }))}
                    placeholder="输入成员名"
                    className="min-w-0 flex-1 bg-transparent text-sm text-[var(--text-primary)] outline-none placeholder:text-[var(--text-tertiary)]"
                  />
                </div>
                <div className="mt-3 grid grid-cols-2 gap-2">
                  {(addForm.search.trim() ? filteredMembers : allMembers.slice(0, 8)).map((member) => {
                    const active = addForm.members.includes(member);
                    return (
                      <button
                        key={member}
                        type="button"
                        onClick={() => toggleAddMember(member)}
                        className={`rounded-2xl border px-3 py-2 text-left text-sm transition-colors ${
                          active
                            ? 'border-[var(--text-primary)] bg-[var(--text-primary)] text-white'
                            : 'border-[var(--border-primary)] bg-[var(--bg-secondary)] text-[var(--text-secondary)]'
                        }`}
                      >
                        {member}
                      </button>
                    );
                  })}
                </div>
              </div>

              <div className="flex items-center gap-4">
                <div className="flex-1">
                  <label className="text-sm font-semibold text-[var(--text-primary)]">张数</label>
                  <div className="mt-3 flex items-center rounded-2xl border border-[var(--border-primary)] bg-[var(--bg-secondary)] p-1">
                    <button
                      type="button"
                      onClick={() => setAddForm((current) => ({ ...current, tickets: Math.max(1, current.tickets - 1) }))}
                      className="h-10 flex-1 rounded-xl text-lg font-bold text-[var(--text-secondary)]"
                    >
                      -
                    </button>
                    <div className="w-12 text-center text-lg font-bold text-[var(--text-primary)]">{addForm.tickets}</div>
                    <button
                      type="button"
                      onClick={() => setAddForm((current) => ({ ...current, tickets: current.tickets + 1 }))}
                      className="h-10 flex-1 rounded-xl text-lg font-bold text-[var(--text-secondary)]"
                    >
                      +
                    </button>
                  </div>
                </div>
              </div>

              {addForm.members.length > 0 && (
                <div className="rounded-2xl border border-[var(--border-primary)] bg-[var(--bg-secondary)] p-4">
                  <p className="text-xs font-medium text-[var(--text-tertiary)]">将添加</p>
                  <p className="mt-2 text-sm font-semibold text-[var(--text-primary)]">
                    {addForm.date} · {addForm.slots.length > 0 ? `第 ${addForm.slots.join(', ')} 部` : '未选择部数'} · {addForm.members.length} 人 · 每人 {addForm.tickets} 张
                  </p>
                  <div className="mt-3 flex flex-wrap gap-2">
                    {addForm.members.map((member) => (
                      <span key={member} className="rounded-full bg-[var(--bg-primary)] px-3 py-1 text-xs text-[var(--text-secondary)]">
                        {member}
                      </span>
                    ))}
                  </div>
                </div>
              )}
            </div>

            <div className="sticky bottom-0 -mx-6 mt-8 border-t border-[var(--border-primary)] bg-[var(--bg-primary)] p-6">
              <button
                type="button"
                onClick={saveAddForm}
                disabled={addForm.members.length === 0 || addForm.slots.length === 0}
                className="w-full rounded-2xl bg-[var(--text-primary)] px-4 py-3 text-sm font-bold text-white disabled:cursor-not-allowed disabled:opacity-40"
              >
                保存 {addForm.members.length * addForm.slots.length > 0 ? `(${addForm.members.length * addForm.slots.length} 条记录)` : ''}
              </button>
            </div>
          </aside>
        </div>
      )}
    </div>
  );
}
