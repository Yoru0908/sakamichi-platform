---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { 
  title = 'Sakamichi Tools - 坂道系列综合工具平台',
  description = '提供博客翻译、MSG消息归档、周边商城、实用工具等专业服务',
  image = '/images/sakamichi.jpg'
} = Astro.props;

const siteUrl = Astro.site || new URL('https://sakamichi-tools.cn');
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const ogImage = image.startsWith('http') ? image : new URL(image, siteUrl).toString();
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <meta name="theme-color" content="#742581">
  
  <title>{title}</title>
  <link rel="canonical" href={canonicalURL} />
  
  <!-- Favicons -->
  <link rel="icon" type="image/jpeg" href="/images/sakamichi.jpg">
  <link rel="apple-touch-icon" href="/images/sakamichi.jpg">
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:url" content={canonicalURL}>
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;600;700&family=Noto+Sans+JP:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="min-h-screen bg-gray-50 font-sans antialiased">
  <!-- Navigation -->
  <nav class="bg-white border-b border-gray-200 sticky top-0 z-50 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 text-xl font-bold text-gray-900 hover:text-purple-700 transition-colors">
          <span class="text-2xl">Sakamichi Tools</span>
        </a>
        
        <!-- Desktop Navigation -->
        <div class="hidden md:flex items-center gap-8">
          <a href="/blog" class="text-gray-700 hover:text-purple-700 transition-colors font-medium">博客翻译</a>
          <a href="/messages" class="text-gray-700 hover:text-purple-700 transition-colors font-medium">MSG归档</a>
          <a href="/shop" class="text-gray-700 hover:text-purple-700 transition-colors font-medium">周边商城</a>
          <a href="/tools" class="text-gray-700 hover:text-purple-700 transition-colors font-medium">工具</a>
          <a href="/auth/login" class="px-4 py-2 bg-purple-700 text-white rounded-lg hover:bg-purple-800 transition-colors font-medium">登录</a>
        </div>
        
        <!-- Mobile Menu Button -->
        <button id="mobile-menu-btn" class="md:hidden p-2 text-gray-700 hover:text-purple-700">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
    
    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 bg-white">
      <div class="px-4 py-4 space-y-3">
        <a href="/blog" class="block text-gray-700 hover:text-purple-700 transition-colors font-medium">博客翻译</a>
        <a href="/messages" class="block text-gray-700 hover:text-purple-700 transition-colors font-medium">MSG归档</a>
        <a href="/shop" class="block text-gray-700 hover:text-purple-700 transition-colors font-medium">周边商城</a>
        <a href="/tools" class="block text-gray-700 hover:text-purple-700 transition-colors font-medium">工具</a>
        <a href="/auth/login" class="block px-4 py-2 bg-purple-700 text-white rounded-lg hover:bg-purple-800 transition-colors font-medium text-center">登录</a>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <main class="min-h-[calc(100vh-4rem)]">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-white border-t border-gray-200 mt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <!-- About -->
        <div class="col-span-1 md:col-span-2">
          <h3 class="text-lg font-bold text-gray-900 mb-4">Sakamichi Tools</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            为坂道粉丝提供博客翻译、MSG消息归档、周边信息聚合等专业服务。<br>
            内容整合、工具便利、社区友好。
          </p>
        </div>
        
        <!-- Quick Links -->
        <div>
          <h4 class="text-sm font-semibold text-gray-900 mb-4">快速链接</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/blog" class="text-gray-600 hover:text-purple-700">博客翻译</a></li>
            <li><a href="/messages" class="text-gray-600 hover:text-purple-700">MSG归档</a></li>
            <li><a href="/shop" class="text-gray-600 hover:text-purple-700">周边商城</a></li>
            <li><a href="/tools" class="text-gray-600 hover:text-purple-700">工具</a></li>
          </ul>
        </div>
        
        <!-- Legal -->
        <div>
          <h4 class="text-sm font-semibold text-gray-900 mb-4">法律信息</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/privacy" class="text-gray-600 hover:text-purple-700">隐私政策</a></li>
            <li><a href="/terms" class="text-gray-600 hover:text-purple-700">使用条款</a></li>
            <li><a href="/disclaimer" class="text-gray-600 hover:text-purple-700">免责声明</a></li>
          </ul>
        </div>
      </div>
      
      <div class="border-t border-gray-200 mt-8 pt-8 text-center text-sm text-gray-500">
        <p>&copy; {new Date().getFullYear()} Sakamichi Tools. 本站为非官方粉丝项目。</p>
      </div>
    </div>
  </footer>

  <script>
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    
    mobileMenuBtn?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('hidden');
    });
  </script>
</body>
</html>
