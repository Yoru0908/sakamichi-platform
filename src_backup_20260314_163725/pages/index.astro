---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_CONFIG } from '../utils/constants';
---

<BaseLayout>
  <div class="loading-overlay fixed inset-0 bg-white flex flex-col items-center justify-center z-50 transition-opacity duration-1000" id="loadingOverlay">
    <div class="relative w-30 h-30">
      <div class="absolute inset-0 border-2 border-transparent border-t-purple-700 rounded-full animate-spin"></div>
      <div class="absolute inset-0 border-2 border-transparent border-r-pink-400 rounded-full animate-spin" style="animation-direction: reverse; animation-delay: 0.2s;"></div>
      <div class="absolute inset-0 border-2 border-transparent border-b-blue-500 rounded-full animate-spin" style="animation-delay: 0.4s;"></div>
    </div>
    <div class="mt-10 text-sm font-medium tracking-widest text-gray-500 animate-pulse">INITIALIZING</div>
  </div>

  <div class="main-container opacity-0 transition-all duration-800" id="mainContainer">
    <header class="text-center py-20 bg-gradient-to-b from-white to-gray-50">
      <h1 class="text-5xl font-bold text-gray-900 mb-3 tracking-tight">Sakamichi Tools</h1>
      <p class="text-gray-600 text-lg tracking-wide">坂道系列综合工具平台</p>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- 博客翻译 -->
        <div 
          class="service-card group bg-white border border-gray-200 p-12 text-center cursor-pointer relative overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:border-purple-700"
          data-service="blog"
          onclick="window.location.href='/blog'"
        >
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-purple-700 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-600"></div>
          
          <div class="w-18 h-18 mx-auto mb-6 bg-purple-700 rounded-full flex items-center justify-center transition-transform duration-300 group-hover:scale-110">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/>
            </svg>
          </div>
          
          <h2 class="text-2xl font-semibold text-gray-900 mb-3">博客翻译</h2>
          <p class="text-gray-600 text-sm leading-relaxed mb-7">
            坂道成员博客中日翻译<br>实时更新成员最新动态
          </p>
          
          <a href="/blog" class="inline-flex items-center gap-2 px-7 py-3 bg-purple-700 text-white text-sm font-medium transition-all duration-300 hover:translate-x-1 hover:shadow-lg">
            <span>进入博客</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <!-- 生写生成器 -->
        <div 
          class="service-card group bg-white border border-gray-200 p-12 text-center cursor-pointer relative overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:border-pink-400"
          data-service="tools"
          onclick="window.location.href='/tools'"
        >
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-pink-400 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-600"></div>
          
          <div class="w-18 h-18 mx-auto mb-6 bg-pink-400 rounded-full flex items-center justify-center transition-transform duration-300 group-hover:scale-110">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
            </svg>
          </div>
          
          <h2 class="text-2xl font-semibold text-gray-900 mb-3">实用工具</h2>
          <p class="text-gray-600 text-sm leading-relaxed mb-7">
            生写生成器与字幕工具<br>视频字幕处理及多功能生成器
          </p>
          
          <a href="/tools" class="inline-flex items-center gap-2 px-7 py-3 bg-pink-400 text-white text-sm font-medium transition-all duration-300 hover:translate-x-1 hover:shadow-lg">
            <span>进入工具</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <!-- MSG归档 -->
        <div 
          class="service-card group bg-white border border-gray-200 p-12 text-center cursor-pointer relative overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:border-blue-500"
          data-service="msg"
          onclick="window.location.href='/messages'"
        >
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-blue-500 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-600"></div>
          
          <div class="w-18 h-18 mx-auto mb-6 bg-blue-500 rounded-full flex items-center justify-center transition-transform duration-300 group-hover:scale-110">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          
          <h2 class="text-2xl font-semibold text-gray-900 mb-3">MSG归档</h2>
          <p class="text-gray-600 text-sm leading-relaxed mb-7">
            成员消息归档与翻译<br>支持文字、图片、视频、语音
          </p>
          
          <a href="/messages" class="inline-flex items-center gap-2 px-7 py-3 bg-blue-500 text-white text-sm font-medium transition-all duration-300 hover:translate-x-1 hover:shadow-lg">
            <span>查看消息</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- 新增功能预告 -->
      <div class="mt-16 grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-gradient-to-br from-purple-50 to-pink-50 border border-purple-200 p-8 rounded-lg">
          <h3 class="text-xl font-semibold text-gray-900 mb-3">📸 周边商城</h3>
          <p class="text-gray-700 text-sm mb-4">官方周边信息聚合，价格追踪，到货提醒</p>
          <span class="text-xs text-purple-700 font-medium">即将上线</span>
        </div>
        
        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 border border-blue-200 p-8 rounded-lg">
          <h3 class="text-xl font-semibold text-gray-900 mb-3">🎙️ 广播归档</h3>
          <p class="text-gray-700 text-sm mb-4">广播节目归档，双语字幕，时间轴标注</p>
          <span class="text-xs text-blue-700 font-medium">开发中</span>
        </div>
      </div>
    </main>
  </div>

  <script>
    window.addEventListener('load', () => {
      setTimeout(() => {
        const overlay = document.getElementById('loadingOverlay');
        const container = document.getElementById('mainContainer');
        
        overlay?.classList.add('opacity-0', 'pointer-events-none');
        container?.classList.remove('opacity-0');
        
        setTimeout(() => overlay?.remove(), 1000);
      }, 2000);
    });
  </script>
</BaseLayout>
