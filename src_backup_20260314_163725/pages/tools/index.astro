---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="实用工具 - Sakamichi Tools">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">实用工具</h1>
      <p class="text-gray-600">为坂道粉丝提供的各类实用工具集合</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- 生写生成器 -->
      <a href="/tools/photocard" class="group bg-white border border-gray-200 rounded-lg p-8 hover:shadow-xl transition-all hover:-translate-y-1">
        <div class="w-16 h-16 bg-gradient-to-br from-purple-500 to-pink-500 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">生写生成器</h3>
        <p class="text-gray-600 text-sm mb-4">生成官方风格的成员生写卡片，支持自定义文字和样式</p>
        <span class="text-purple-700 text-sm font-medium inline-flex items-center gap-1 group-hover:gap-2 transition-all">
          开始使用
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </span>
      </a>

      <!-- 字幕底图制作 -->
      <a href="/tools/subtitle" class="group bg-white border border-gray-200 rounded-lg p-8 hover:shadow-xl transition-all hover:-translate-y-1">
        <div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-indigo-500 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">字幕底图制作</h3>
        <p class="text-gray-600 text-sm mb-4">为视频字幕生成美观的底图背景，多种样式可选</p>
        <span class="text-blue-700 text-sm font-medium inline-flex items-center gap-1 group-hover:gap-2 transition-all">
          开始使用
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </span>
      </a>

      <!-- MSG样式生成器 -->
      <a href="/tools/msg-generator" class="group bg-white border border-gray-200 rounded-lg p-8 hover:shadow-xl transition-all hover:-translate-y-1">
        <div class="w-16 h-16 bg-gradient-to-br from-pink-500 to-rose-500 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">MSG样式生成器</h3>
        <p class="text-gray-600 text-sm mb-4">生成官方 MSG 消息样式的图片，支持自定义头像和文字</p>
        <span class="text-pink-700 text-sm font-medium inline-flex items-center gap-1 group-hover:gap-2 transition-all">
          开始使用
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </span>
      </a>
    </div>

    <!-- 使用说明 -->
    <div class="mt-12 bg-gradient-to-br from-gray-50 to-gray-100 border border-gray-200 rounded-lg p-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">使用说明</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-sm">
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">📱 移动端优化</h3>
          <p class="text-gray-600">所有工具均支持移动端访问，响应式设计，随时随地使用</p>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">🎨 自定义选项</h3>
          <p class="text-gray-600">丰富的自定义选项，包括字体、颜色、样式等</p>
        </div>
        <div>
          <h3 class="font-semibent text-gray-900 mb-2">💾 本地处理</h3>
          <p class="text-gray-600">所有图片处理均在本地完成，保护您的隐私</p>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">🆓 完全免费</h3>
          <p class="text-gray-600">所有工具完全免费使用，无需注册登录</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
