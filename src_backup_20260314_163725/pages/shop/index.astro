---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_CONFIG } from '../../utils/constants';

const groups = Object.values(SITE_CONFIG.groups);
---

<BaseLayout title="周边商城 - Sakamichi Tools">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">周边商城</h1>
      <p class="text-gray-600">官方周边信息聚合，价格追踪，到货提醒</p>
      
      <div class="mt-6 bg-blue-50 border border-blue-200 rounded-lg p-4">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <div class="text-sm text-blue-800">
            <p class="font-medium mb-1">商城说明</p>
            <ul class="space-y-1 text-xs">
              <li>• 本站仅提供商品信息展示，不经手交易</li>
              <li>• 点击"官网购买"跳转到官方商城</li>
              <li>• 点击"代购购买"跳转到代购平台</li>
              <li>• 登录用户可设置价格提醒和到货通知</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- 团体切换 -->
    <div class="flex gap-4 mb-8 border-b border-gray-200">
      {groups.map((group) => (
        <button 
          class="px-6 py-3 text-sm font-medium border-b-2 transition-colors shop-tab"
          style="border-color: transparent"
          data-group={group.siteKey}
        >
          {group.name}
        </button>
      ))}
    </div>

    <!-- 商品网格 -->
    <div id="product-grid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
      {[...Array(8)].map(() => (
        <div class="bg-white border border-gray-200 rounded-lg overflow-hidden hover:shadow-lg transition-shadow">
          <div class="aspect-square bg-gray-200 animate-pulse"></div>
          <div class="p-4">
            <div class="h-4 bg-gray-200 rounded animate-pulse mb-2"></div>
            <div class="h-6 bg-gray-200 rounded animate-pulse w-24 mb-3"></div>
            <div class="flex gap-2">
              <div class="h-9 bg-gray-200 rounded animate-pulse flex-1"></div>
              <div class="h-9 bg-gray-200 rounded animate-pulse flex-1"></div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- 功能预告 -->
    <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-gradient-to-br from-purple-50 to-pink-50 border border-purple-200 rounded-lg p-6">
        <div class="w-12 h-12 bg-purple-500 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">到货提醒</h3>
        <p class="text-gray-600 text-sm">商品从缺货变为有货时，通过邮件/Discord 通知您</p>
      </div>
      
      <div class="bg-gradient-to-br from-blue-50 to-indigo-50 border border-blue-200 rounded-lg p-6">
        <div class="w-12 h-12 bg-blue-500 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">价格追踪</h3>
        <p class="text-gray-600 text-sm">自动记录价格变化历史，降价时及时通知</p>
      </div>
      
      <div class="bg-gradient-to-br from-green-50 to-emerald-50 border border-green-200 rounded-lg p-6">
        <div class="w-12 h-12 bg-green-500 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">拼单功能</h3>
        <p class="text-gray-600 text-sm">发起或加入拼单，降低国际运费成本</p>
      </div>
    </div>

    <!-- 提示信息 -->
    <div class="mt-12 text-center">
      <div class="inline-block bg-orange-50 border border-orange-200 rounded-lg px-6 py-4">
        <p class="text-orange-800 text-sm">
          🚧 商城功能开发中，将接入官方商城爬虫数据
        </p>
      </div>
    </div>
  </div>

  <script>
    const tabs = document.querySelectorAll('.shop-tab');
    tabs.forEach((tab, index) => {
      if (index === 0) {
        tab.style.borderColor = '#742581';
        tab.classList.add('text-purple-700');
      }
      
      tab.addEventListener('click', () => {
        tabs.forEach(t => {
          t.style.borderColor = 'transparent';
          t.classList.remove('text-purple-700', 'text-pink-400', 'text-blue-500');
        });
        
        const colors: Record<string, string> = {
          'nogizaka': '#742581',
          'sakurazaka': '#F19DB5',
          'hinatazaka': '#3b82f6'
        };
        
        const group = tab.dataset.group || 'nogizaka';
        tab.style.borderColor = colors[group];
        
        if (group === 'nogizaka') tab.classList.add('text-purple-700');
        if (group === 'sakurazaka') tab.classList.add('text-pink-400');
        if (group === 'hinatazaka') tab.classList.add('text-blue-500');
      });
    });
  </script>
</BaseLayout>
